# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# JWT（必填，缺少會拒絕啟動）
JWT_SECRET=change_this_to_a_long_random_secret

# LINE Bot
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LIFF_ID=your_liff_id

# PostgreSQL（必填）
# pooler URL（port 6543）— 應用程式 runtime 用
DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true
# direct URL（port 5432）— prisma migrate / db push 用
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Optional: 額外 CORS 白名單（逗號分隔）
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://preview.example.com

# Optional: Finnhub（備用股價來源）
# FINNHUB_API_KEY=your_finnhub_api_key
